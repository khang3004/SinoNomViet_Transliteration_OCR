# Secrets — NEVER commit real keys (AGENTS.md §7). Only .env.example is tracked.
.env
*.key
# The repo-root .gitignore has ".env.*" which also hides .env.example; keep the
# placeholder template tracked (it has empty values only).
!.env.example

# Runtime state — lives in the mounted data/ volume, not in git/the image.
data/
!data/.gitkeep

# Local OCR worker env + portable poppler (not committed; see SHARE.md)
.venv*/
.tools/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
coverage.xml
.mypy_cache/
.ruff_cache/

# Keep project docs under hannom-app (root .gitignore ignores docs/)
!docs/
!docs/**
