# hannom-app — environment template (AGENTS.md §6, §7).
# Copy to `.env` and fill values. `.env` is gitignored; NEVER commit real keys.
# Maps 1:1 to a K8s Secret + envFrom later (no code change).

# --- backends ---------------------------------------------------------------
# OCR engine: paddle (default, fits the 2060 GPU) | vision (Google Vision API)
OCR_BACKEND=paddle
# Paddle GPU toggle: 1 = GPU (default), 0 = CPU (GPU-less hosts, e.g. sharing from a laptop)
OCR_USE_GPU=1
# Paddle language model. chinese_cht = Traditional Chinese (best for classical
# Sino-Nom / Hán-Nôm woodblock & typeset text); ch = Simplified.
OCR_LANG=chinese_cht
# Translation: api = Gemini flash (default, cheap) | offline (NOT for the 2060)
TRANSLATE_BACKEND=api
# Han OCR correction: skip (default, han==han_raw) | api (Gemini, needs
# GOOGLE_API_KEY — best quality) | dict (S1∩S2 via dicts/, only as good as the
# dictionaries) | offline (stub).
CORRECT_BACKEND=skip
# Gemini model for CORRECT_BACKEND=api (defaults to gemini-2.0-flash):
CORRECT_MODEL=gemini-2.0-flash
# Offline LLM (only if TRANSLATE/CORRECT=offline AND a bigger GPU is available):
QWEN_MODEL=Qwen2.5-3B-Instruct

# --- work identity / rendering ---------------------------------------------
DSG_FFF=HVB_001
PDF_DPI=300

# --- API keys (worker only; read from env, never logged) -------------------
# Required when TRANSLATE_BACKEND=api or CORRECT_BACKEND=api (Gemini):
GOOGLE_API_KEY=
# Required when OCR_BACKEND=vision:
GOOGLE_VISION_KEY=
