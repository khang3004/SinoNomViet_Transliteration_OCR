# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — SinoNom OCR Pipeline
# ─────────────────────────────────────────────────────────────────────────────

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

docs/

# ── uv ───────────────────────────────────────────────────────────────────────
# Keep uv.lock committed — it pins exact versions for reproducibility
# uv.lock   ← do NOT gitignore this

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.cover
.hypothesis/

# ── Linter / type checker caches ─────────────────────────────────────────────
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints/
# Keep executed notebooks OUT of git (they can be huge and noisy)
output/executed_*.ipynb
output/executed_notebooks/

# ── Raw image data (large binary files — use Git LFS or store separately) ────
data/raw_images/
# If you want to commit a small sample set, override with:
# !data/raw_images/sample/

# ── Generated outputs ─────────────────────────────────────────────────────────
output/xml/
output/excel/
# Keep the directory structure via .gitkeep
!output/xml/.gitkeep
!output/excel/.gitkeep
data/ocr_layout_output.json

# ── OS / IDE ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# JetBrains IDEs
.idea/

# VS Code
.vscode/
*.code-workspace

# Claude Code local config / worktrees
.claude/

# ── Local scratch data dirs (not the app's ./data volume) ────────────────────
hannom-app/data_t/
hannom-app/data_test/

# ── Secrets / credentials ─────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
secrets/
credentials.json
